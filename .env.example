# Copia este archivo a ".env" y pega tu API key de OpenRouter.
# Consíguela GRATIS en https://openrouter.ai/keys (no requiere tarjeta).
OPENROUTER_API_KEY=

# Opcional: si algún día usas la API directa de DeepSeek o DashScope/Qwen
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# Opcional: datos de mercado más ricos (llaves GRATIS, se registran en sus webs).
# Sin estas llaves, el bot usa noticias por RSS y proxy de ballenas del exchange.
# CryptoPanic (noticias + sentimiento): https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=
# Whale Alert (movimientos on-chain de ballenas): https://whale-alert.io/
WHALE_ALERT_API_KEY=

# Telegram (para recibir señales y resultados 24/7 en el celular — GRATIS).
# 1) Habla con @BotFather en Telegram → /newbot → te da el TOKEN.
# 2) Habla con @userinfobot → te da tu CHAT_ID (número).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
